-- ============================================
-- WINDOW CLASS
-- ============================================
local Window = {}
Window.__index = Window

function Window.new(title: string, width: number?, height: number?): Window
	local self = setmetatable({}, Window) :: any
	
	self.title = title
	self.width = width or 350
	self.height = height or 450
	self.isOpen = true
	self.mainGui = nil :: ScreenGui?
	self.mainFrame = nil :: Frame?
	self.content = nil :: Frame?
	self.connections = {} :: {RBXScriptConnection}
	self.elements = {} :: {Button | Toggle | Slider}
	self.tabs = {} :: {Tab}
	self.currentTab = nil :: Tab?
	self.isDragging = false
	self.dragOffset = Vector2.new(0, 0)
	self.closed = Signal.new()
	
	self:_Create()
	return self
end

function Window:_Create(): ()
	if self.mainGui then self.mainGui:Destroy() end

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "GuiWindow_" .. self.title
	screenGui.ResetOnSpawn = false
	screenGui.Parent = playerGui

	local mainFrame = Instance.new("Frame")
	mainFrame.Name = "MainFrame"
	mainFrame.Size = UDim2.new(0, self.width, 0, self.height)
	mainFrame.Position = UDim2.new(0.5, -self.width / 2, 0.5, -self.height / 2)
	mainFrame.BackgroundColor3 = CONFIG.MAIN_COLOR
	mainFrame.BorderColor3 = CONFIG.ACCENT_COLOR
	mainFrame.BorderSizePixel = 2
	mainFrame.Parent = screenGui

	self.mainFrame = mainFrame
	self.mainGui = screenGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = mainFrame

	-- Title Bar
	local titleBar = Instance.new("Frame")
	titleBar.Name = "TitleBar"
	titleBar.Size = UDim2.new(1, 0, 0, 35)
	titleBar.BackgroundColor3 = CONFIG.ACCENT_COLOR
	titleBar.BorderSizePixel = 0
	titleBar.Parent = mainFrame

	local titleCorner = Instance.new("UICorner")
	titleCorner.CornerRadius = UDim.new(0, 8)
	titleCorner.Parent = titleBar

	local clipping = Instance.new("ClipDescendants")
	clipping.Parent = titleBar

	local titleText = Instance.new("TextLabel")
	titleText.Size = UDim2.new(1, -70, 1, 0)
	titleText.BackgroundTransparency = 1
	titleText.TextColor3 = CONFIG.TEXT_COLOR
	titleText.TextSize = 13
	titleText.Font = Enum.Font.GothamBold
	titleText.Text = self.title
	titleText.TextXAlignment = Enum.TextXAlignment.Left
	titleText.Parent = titleBar

	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, 12)
	padding.Parent = titleText

	-- Close Button
	local closeBtn = Instance.new("TextButton")
	closeBtn.Name = "CloseBtn"
	closeBtn.Size = UDim2.new(0, 30, 0, 30)
	closeBtn.Position = UDim2.new(1, -35, 0.5, -15)
	closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
	closeBtn.TextColor3 = CONFIG.TEXT_COLOR
	closeBtn.Text = "x"
	closeBtn.TextSize = 18
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.BorderSizePixel = 0
	closeBtn.Parent = titleBar

	local closeCorner = Instance.new("UICorner")
	closeCorner.CornerRadius = UDim.new(0, 4)
	closeCorner.Parent = closeBtn

	table.insert(self.connections, closeBtn.MouseButton1Click:Connect(function()
		if not mainFrame.Parent then return end
		self:Close()
	end))

	-- Dragging
	table.insert(self.connections, titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			if self.isDragging then return end
			self.isDragging = true
			local mousePos = UserInputService:GetMouseLocation()
			self.dragOffset = Vector2.new(
				mousePos.X - mainFrame.AbsolutePosition.X,
				mousePos.Y - mainFrame.AbsolutePosition.Y
			)
		end
	end))

	table.insert(self.connections, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			self.isDragging = false
		end
	end))

	-- Tabs Bar
	local tabsContainer = Instance.new("Frame")
	tabsContainer.Name = "TabsContainer"
	tabsContainer.Size = UDim2.new(1, 0, 0, 40)
	tabsContainer.Position = UDim2.new(0, 0, 0, 35)
	tabsContainer.BackgroundColor3 = CONFIG.SECONDARY_COLOR
	tabsContainer.BorderSizePixel = 0
	tabsContainer.Parent = mainFrame

	local tabsLayout = Instance.new("UIListLayout")
	tabsLayout.Padding = UDim.new(0, 5)
	tabsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tabsLayout.Parent = tabsContainer

	local tabsPadding = Instance.new("UIPadding")
	tabsPadding.PaddingLeft = UDim.new(0, 8)
	tabsPadding.PaddingRight = UDim.new(0, 8)
	tabsPadding.PaddingTop = UDim.new(0, 5)
	tabsPadding.PaddingBottom = UDim.new(0, 5)
	tabsPadding.Parent = tabsContainer

	self.tabsContainer = tabsContainer

	-- Content (for compatibility with non-tabs)
	local content = Instance.new("Frame")
	content.Name = "Content"
	content.Size = UDim2.new(1, 0, 1, -75)
	content.Position = UDim2.new(0, 0, 0, 75)
	content.BackgroundTransparency = 1
	content.BorderSizePixel = 0
	content.Parent = mainFrame

	local uiListLayout = Instance.new("UIListLayout")
	uiListLayout.Padding = UDim.new(0, 10)
	uiListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	uiListLayout.Parent = content

	local contentPadding = Instance.new("UIPadding")
	contentPadding.PaddingLeft = UDim.new(0, 12)
	contentPadding.PaddingRight = UDim.new(0, 12)
	contentPadding.PaddingTop = UDim.new(0, 10)
	contentPadding.PaddingBottom = UDim.new(0, 10)
	contentPadding.Parent = content

	self.content = content

	-- Main Loop
	table.insert(self.connections, RunService.RenderStepped:Connect(function()
		if not mainFrame.Parent then return end

		if self.isDragging then
			local mousePos = UserInputService:GetMouseLocation()
			local newX = mousePos.X - self.dragOffset.X
			local newY = mousePos.Y - self.dragOffset.Y
			
			local screenSize = mainFrame.Parent.AbsoluteSize
			local frameSize = mainFrame.AbsoluteSize
			
			newX = math.clamp(newX, 0, screenSize.X - frameSize.X)
			newY = math.clamp(newY, 0, screenSize.Y - frameSize.Y)
			
			mainFrame.Position = UDim2.new(0, newX, 0, newY)
		end
	end))
end

function Window:CreateTab(name: string): Tab
	if not self.mainFrame or not self.mainFrame.Parent then return nil :: any end
	
	local tab = Tab.new(name, self)
	tab:_Create(self.tabsContainer)
	
	table.insert(self.tabs, tab)
	
	if not self.currentTab then
		self:_SelectTab(tab)
	end
	
	return tab
end

function Window:_SelectTab(tab: Tab): ()
	if self.currentTab then
		self.currentTab.button.BackgroundColor3 = CONFIG.SECONDARY_COLOR
		if self.currentTab.content then
			self.currentTab.content.Visible = false
		end
		self.currentTab.isActive = false
	end
	
	tab.button.BackgroundColor3 = CONFIG.ACCENT_COLOR
	if tab.content then
		tab.content.Visible = true
	end
	tab.isActive = true
	self.currentTab = tab
end

function Window:CreateButton(name: string, text: string, callback: (() -> ())?): Button
	if not self.mainFrame or not self.mainFrame.Parent then return nil :: any end
	local btn = Button.new(name, text, self.content :: Frame, callback)
	table.insert(self.elements, btn)
	return btn
end

function Window:CreateToggle(name: string, label: string, defaultValue: boolean?, callback: ((boolean) -> ())?): Toggle
	if not self.mainFrame or not self.mainFrame.Parent then return nil :: any end
	local toggle = Toggle.new(name, label, self.content :: Frame, defaultValue, callback)
	table.insert(self.elements, toggle)
	return toggle
end

function Window:CreateSlider(name: string, label: string, minVal: number, maxVal: number, defaultVal: number, callback: ((number) -> ())?): Slider
	if not self.mainFrame or not self.mainFrame.Parent then return nil :: any end
	local slider = Slider.new(name, label, self.content :: Frame, minVal, maxVal, defaultVal, callback)
	table.insert(self.elements, slider)
	return slider
end

function Window:Close(): ()
	self.isOpen = false
	self:_Cleanup()
	self.closed:Fire()
end

function Window:Destroy(): ()
	self:_Cleanup()
	self.closed:Destroy()
end

function Window:_Cleanup(): ()
	for _, conn in ipairs(self.connections) do
		if conn then conn:Disconnect() end
	end
	self.connections = {}
	
	for _, elem in ipairs(self.elements) do
		if elem and elem.Destroy then elem:Destroy() end
	end
	self.elements = {}
	
	for _, tab in ipairs(self.tabs) do
		if tab.content then tab.content:Destroy() end
	end
	self.tabs = {}
	
	if self.mainGui then self.mainGui:Destroy() end
	self.mainFrame = nil
	self.mainGui = nil
end

